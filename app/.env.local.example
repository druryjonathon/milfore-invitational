# Copy this file to .env.local and fill in your Supabase project's values
# (Project Settings -> API in the Supabase dashboard).
#
# VITE_SUPABASE_ANON_KEY is the public "anon" key, safe for a browser app —
# it is NOT the service_role key and NOT the Postgres connection string used
# by scripts/migrate/. Access control is enforced by RLS policies in
# milfore_schema_v2.sql (public read on everything this app queries).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
