# Copy this file to `.env` and fill in the real value below.
# Get this from the Supabase dashboard: Project Settings -> Database -> Connection string (URI).
# Use the "Session pooler" or direct connection string (port 5432), not the pgbouncer
# transaction-mode pooler (port 6543) — the migration script needs a plain session.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
